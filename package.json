{
  "name": "pr-clubhouse-lint-action",
  "version": "1.0.0",
  "description": "A GitHub Action that verifies your pull request contains a reference to a Shortcut card. If your Shortcut card number is 1234, this will check for `[ch1234]` or `ch1234/` in:",
  "homepage": "https://github.com/movableink/pr-clubhouse-lint-action#readme",
  "bugs": {
    "url": "https://github.com/movableink/pr-clubhouse-lint-action/issues"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.js --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "esbuild": "^0.27.4",
    "jest": "^30.0.0"
  }
}
